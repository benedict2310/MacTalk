<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Identity -->
	<key>CFBundleIdentifier</key>
	<string>com.mactalk.app</string>

	<key>CFBundleName</key>
	<string>MacTalk</string>

	<key>CFBundleDisplayName</key>
	<string>MacTalk</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>

	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Minimum macOS Version -->
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>

	<!-- Menu Bar App (no Dock icon) -->
	<key>LSUIElement</key>
	<true/>

	<!-- High Resolution Capable -->
	<key>NSHighResolutionCapable</key>
	<true/>

	<!-- Principal Class -->
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- Main Nib (if using storyboards) -->
	<key>NSMainNibFile</key>
	<string>MainMenu</string>

	<!-- Supported Platforms -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>

	<!-- Privacy Permissions -->

	<!-- Microphone Access -->
	<key>NSMicrophoneUsageDescription</key>
	<string>MacTalk needs microphone access to transcribe your voice using on-device Whisper AI. All processing happens locally on your Mac.</string>

	<!-- Accessibility (for auto-paste) -->
	<key>NSAppleEventsUsageDescription</key>
	<string>MacTalk needs accessibility permission to auto-paste transcribed text at your cursor position. This is optional and can be disabled in settings.</string>

	<!-- Screen Recording (for app audio capture) -->
	<!-- Note: ScreenCaptureKit handles this automatically via runtime prompts -->
	<!-- No plist key required for macOS 12.3+ -->

	<!-- Additional Capabilities -->

	<!-- Background Modes (if needed for audio) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>

	<!-- Document Types (if supporting file import/export) -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Text Document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.plain-text</string>
			</array>
		</dict>
	</array>

	<!-- URL Schemes (if needed) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.mactalk.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>mactalk</string>
			</array>
		</dict>
	</array>

	<!-- App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow arbitrary loads for model downloads (HTTPS preferred) -->
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>huggingface.co</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
		</dict>
	</dict>

	<!-- Hardened Runtime (for notarization) -->
	<!-- These are set in Xcode signing settings, not Info.plist -->

	<!-- Copyright -->
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2025 MacTalk Development Team. All rights reserved.</string>

	<!-- Application Icon -->
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>

	<!-- Support Files -->
	<key>CFBundleSupportedPlatforms</key>
	<array>
		<string>MacOSX</string>
	</array>
</dict>
</plist>

.rvmrc

# Performance profiling
*.trace
*.speedscope

# Instruments data
*.trace/
*.dtps

# Screenshots and recordings (unless explicitly added)
screenshots/
recordings/

# Backup files
*.backup

# Auto-generated files
*-Bridging-Header.h.bak

# Claude Code configuration (contains project-specific instructions)
CLAUDE.md
.claude/

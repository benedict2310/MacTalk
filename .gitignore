*.bak
*.orig
*.rej
*~.nib
local.properties
.project
.classpath
.settings/
.loadpath

# Ignore bundler config
/.bundle

# Ignore temporary API keys (if any)
api_keys.plist
secrets.plist
config/secrets.yml

# User-specific files
*.suo
*.user
*.sln.docstates

# Build results specific to MacTalk
MacTalk.app/
MacTalk.dSYM/
MacTalk.app.dSYM.zip

# Distribution files
dist/
release/
MacTalk-*.dmg

# Documentation build artifacts
docs/site/
site/

# Jupyter Notebook (if used for analysis)
.ipynb_checkpoints

# pyenv (if using Python tools)
.python-version

# Node modules (if using any JS tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ruby (if using fastlane extensively)
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/

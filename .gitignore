# MacTalk .gitignore

## macOS System Files
.DS_Store
.AppleDouble
.LSOverride

# Icon files
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

## Xcode
# Build artifacts
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint
*.xcscheme
!*.xcscheme.shared

# Xcode Workspace
*.xcworkspace
!default.xcworkspace

# AppCode
.idea/

# SwiftPM
.swiftpm/
.build/
Packages/
Package.pins
Package.resolved
# Note: We track MacTalk.xcodeproj since it's our main project
# *.xcodeproj/

# CocoaPods
Pods/
!Podfile
!Podfile.lock

# Carthage
Carthage/Build/
Carthage/Checkouts/

# Accio
Dependencies/
.accio/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
fastlane/README.md

## Swift
# Swift Package Manager
.swiftpm/config/registries.json
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.netrc

# Playground
timeline.xctimeline
playground.xcworkspace

# Swift compiled files
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Obj-C/Swift specific
*.moved-aside
*.swp
!.gitkeep

## Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

## MacTalk Specific

# Downloaded Whisper models (too large for git)
MacTalk/Resources/Models/*.bin
MacTalk/Resources/Models/*.gguf

# Compiled whisper.cpp library
MacTalk/Libraries/libwhisper.a
MacTalk/Libraries/*.a
MacTalk/Libraries/*.dylib

# Metal compiled shaders (generated)
MacTalk/Resources/*.metallib

# User data and logs
MacTalk/Logs/
MacTalk/Cache/

# Temporary files
*.tmp
*.temp
*.log
*.swp
*.swo
*~

# macOS Keychain (never commit!)
*.keychain
*.keychain-db

# Provisioning profiles
*.mobileprovision
*.provisionprofile

# Code signing
*.p12
*.cer
*.certSigningRequest

# App archives
*.ipa
*.app.zip
*.pkg
*.dmg

## CMake (for whisper.cpp build)
Vendor/whisper.cpp/build/
Vendor/whisper.cpp/cmake-build-*/
Vendor/libfvad/build/

